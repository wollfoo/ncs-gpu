{
  "dashboard": {
    "id": null,
    "uid": "opus-gpu-main",
    "title": "OPUS-GPU System Dashboard",
    "tags": ["gpu", "monitoring", "opus"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 0,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
        "type": "graph",
        "title": "GPU Utilization",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "opus_gpu_utilization_percent",
            "legendFormat": "GPU {{device_id}} - {{device_name}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {
            "format": "percent",
            "min": 0,
            "max": 100,
            "show": true
          }
        ]
      },
      {
        "id": 2,
        "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
        "type": "graph",
        "title": "GPU Memory Usage",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "opus_gpu_memory_used_bytes / opus_gpu_memory_total_bytes * 100",
            "legendFormat": "GPU {{device_id}} Memory %",
            "refId": "A"
          }
        ],
        "yaxes": [
          {
            "format": "percent",
            "min": 0,
            "max": 100,
            "show": true
          }
        ]
      },
      {
        "id": 3,
        "gridPos": { "x": 0, "y": 8, "w": 8, "h": 6 },
        "type": "stat",
        "title": "Tasks Submitted",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "rate(opus_tasks_submitted_total[5m])",
            "legendFormat": "Tasks/sec",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 100, "color": "yellow" },
                { "value": 1000, "color": "red" }
              ]
            },
            "unit": "reqps"
          }
        }
      },
      {
        "id": 4,
        "gridPos": { "x": 8, "y": 8, "w": 8, "h": 6 },
        "type": "stat",
        "title": "Task Success Rate",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "(opus_tasks_status{status='completed'} / opus_tasks_submitted_total) * 100",
            "legendFormat": "Success %",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "value": 0, "color": "red" },
                { "value": 90, "color": "yellow" },
                { "value": 95, "color": "green" }
              ]
            },
            "unit": "percent",
            "min": 0,
            "max": 100
          }
        }
      },
      {
        "id": 5,
        "gridPos": { "x": 16, "y": 8, "w": 8, "h": 6 },
        "type": "gauge",
        "title": "GPU Temperature",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "avg(opus_gpu_temperature_celsius)",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "value": 0, "color": "blue" },
                { "value": 60, "color": "green" },
                { "value": 75, "color": "yellow" },
                { "value": 85, "color": "red" }
              ]
            },
            "unit": "celsius",
            "min": 0,
            "max": 100
          }
        }
      },
      {
        "id": 6,
        "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
        "type": "heatmap",
        "title": "Task Duration Heatmap",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(opus_task_duration_seconds_bucket[5m]))",
            "format": "heatmap",
            "refId": "A"
          }
        ],
        "dataFormat": "timeseries",
        "cards": {
          "cardPadding": 2,
          "cardRound": 2
        },
        "color": {
          "mode": "spectrum",
          "scheme": "interpolateSpectral"
        }
      },
      {
        "id": 7,
        "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
        "type": "graph",
        "title": "Request Latency (P50, P95, P99)",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(opus_request_latency_seconds_bucket[5m]))",
            "legendFormat": "P50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(opus_request_latency_seconds_bucket[5m]))",
            "legendFormat": "P95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, rate(opus_request_latency_seconds_bucket[5m]))",
            "legendFormat": "P99",
            "refId": "C"
          }
        ],
        "yaxes": [
          {
            "format": "s",
            "logBase": 1,
            "show": true
          }
        ]
      },
      {
        "id": 8,
        "gridPos": { "x": 0, "y": 22, "w": 8, "h": 6 },
        "type": "piechart",
        "title": "Task Status Distribution",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "opus_tasks_status",
            "legendFormat": "{{status}}",
            "refId": "A"
          }
        ],
        "pieType": "donut",
        "legendDisplayMode": "table",
        "legendPlacement": "right"
      },
      {
        "id": 9,
        "gridPos": { "x": 8, "y": 22, "w": 8, "h": 6 },
        "type": "graph",
        "title": "GPU Power Usage",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "opus_gpu_power_usage_watts",
            "legendFormat": "GPU {{device_id}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {
            "format": "watt",
            "show": true
          }
        ]
      },
      {
        "id": 10,
        "gridPos": { "x": 16, "y": 22, "w": 8, "h": 6 },
        "type": "table",
        "title": "Top CUDA Kernels by Execution Time",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "topk(10, sum(rate(opus_cuda_kernel_time_seconds_sum[5m])) by (kernel_name))",
            "format": "table",
            "refId": "A"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "renameByName": {
                "kernel_name": "Kernel",
                "Value": "Time (s/s)"
              }
            }
          }
        ]
      }
    ],
    "templating": {
      "list": [
        {
          "name": "gpu_device",
          "type": "query",
          "datasource": "Prometheus",
          "query": "label_values(opus_gpu_utilization_percent, device_id)",
          "regex": "",
          "sort": 1,
          "tagValuesQuery": "",
          "tagsQuery": "",
          "useTags": false,
          "multi": true,
          "includeAll": true,
          "current": {
            "text": "All",
            "value": "$__all"
          }
        }
      ]
    },
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"],
      "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
    }
  }
}
