{
  "name": "@opus-gpu/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Opus GPU orchestration and monitoring",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "clean": "rm -rf dist",
    "docs": "typedoc",
    "benchmark": "node dist/benchmark.js"
  },
  "keywords": [
    "gpu",
    "cuda",
    "orchestration",
    "monitoring",
    "performance",
    "typescript"
  ],
  "author": "Opus GPU Team",
  "license": "PROPRIETARY",
  "dependencies": {
    "@grpc/grpc-js": "^1.9.0",
    "@grpc/proto-loader": "^0.7.0",
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/auto-instrumentations-node": "^0.40.0",
    "@opentelemetry/exporter-jaeger": "^1.17.0",
    "@opentelemetry/exporter-prometheus": "^0.46.0",
    "@opentelemetry/sdk-node": "^0.46.0",
    "commander": "^11.0.0",
    "yaml": "^2.3.0",
    "joi": "^17.11.0",
    "winston": "^3.11.0",
    "nats": "^2.18.0",
    "redis": "^4.6.0",
    "prometheus-api-metrics": "^3.2.0",
    "node-cron": "^3.0.0",
    "chalk": "^4.1.2",
    "ora": "^5.4.1",
    "inquirer": "^8.2.6",
    "table": "^6.8.0",
    "fast-csv": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/jest": "^29.5.0",
    "@types/inquirer": "^8.2.6",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.45.0",
    "jest": "^29.6.0",
    "ts-jest": "^29.1.0",
    "typedoc": "^0.25.0",
    "typescript": "^5.1.0"
  },
  "bin": {
    "opus-gpu": "dist/cli/index.js",
    "opus-monitor": "dist/cli/monitor.js",
    "opus-benchmark": "dist/cli/benchmark.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/opus-gpu/app-gpu.git",
    "directory": "tooling/ts-sdk"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/**/*.test.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "eslintConfig": {
    "extends": [
      "@typescript-eslint/recommended"
    ],
    "parser": "@typescript-eslint/parser",
    "plugins": [
      "@typescript-eslint"
    ],
    "rules": {
      "@typescript-eslint/no-unused-vars": "error",
      "@typescript-eslint/no-explicit-any": "warn",
      "@typescript-eslint/explicit-function-return-type": "warn"
    }
  }
}
