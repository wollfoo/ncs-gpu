# App-GPU Environment Variables Example
# Copy this file to .env and fill in your values
# Sao chép file này thành .env và điền giá trị của bạn

# ==============================================================================
# GPU Settings (Cài đặt GPU)
# ==============================================================================

# GPU device ID (0 for first GPU)
GPU_DEVICE_ID=0

# GPU power limit in watts
GPU_POWER_LIMIT=250

# Target GPU utilization (0.0-1.0)
GPU_TARGET_UTILIZATION=0.85

# ==============================================================================
# Mining Pool Configuration (Cấu hình Pool Khai thác)
# ==============================================================================

# Mining pool URL
# Examples:
#   Monero: stratum+tcp://pool.supportxmr.com:3333
#   Ethereum: stratum+tcp://eth-us-west1.nanopool.org:9999
MINING_POOL_URL=stratum+tcp://pool.example.com:3333

# Your wallet address
MINING_WALLET=YOUR_WALLET_ADDRESS_HERE

# Worker name (optional)
MINING_WORKER=worker1

# Pool password (usually "x")
MINING_PASSWORD=x

# ==============================================================================
# Cloaking Settings (Cài đặt Ngụy trang)
# ==============================================================================

# Enable cloaking (true/false)
CLOAKING_ENABLED=true

# Cloaking strategy: adaptive, training, inference, complex
CLOAKING_STRATEGY=adaptive

# VRAM allocation (0.0-1.0)
CLOAKING_VRAM_ALLOCATION=0.50

# Power variation (0.0-1.0)
CLOAKING_POWER_VARIATION=0.12

# Cycle duration in seconds
CLOAKING_CYCLE_DURATION=90

# ==============================================================================
# Resource Manager (Quản lý Tài nguyên)
# ==============================================================================

# Enable QoS enforcement
QOS_ENABLED=true

# CPU limit (0.0-1.0)
CPU_LIMIT=0.80

# GPU limit (0.0-1.0)
GPU_LIMIT=0.95

# Network bandwidth limit in Mbps (leave empty for no limit)
NETWORK_LIMIT_MBPS=100

# ==============================================================================
# Security (Bảo mật)
# ==============================================================================

# Enable mTLS (requires certificates)
MTLS_ENABLED=false

# Certificate paths (if mTLS enabled)
# CERT_PATH=/etc/app-gpu/certs/server.crt
# KEY_PATH=/etc/app-gpu/certs/server.key

# Verify plugin signatures
VERIFY_PLUGINS=true

# Secrets vault path
SECRETS_PATH=/var/lib/app-gpu/secrets

# ==============================================================================
# Telemetry (Giám sát)
# ==============================================================================

# Enable Prometheus metrics
PROMETHEUS_ENABLED=true

# Prometheus listen address
PROMETHEUS_ADDR=0.0.0.0:9090

# Metrics collection interval (seconds)
METRICS_INTERVAL_SECS=30

# Log directory
LOG_DIR=/var/log/app-gpu

# ==============================================================================
# Logging (Ghi nhật ký)
# ==============================================================================

# Log level: trace, debug, info, warn, error
RUST_LOG=info

# Enable backtrace on panic
RUST_BACKTRACE=1

# JSON logs (true/false)
JSON_LOGS=false

# ==============================================================================
# Grafana (Optional - for docker-compose)
# ==============================================================================

# Grafana admin password
GRAFANA_PASSWORD=admin
