# Environment configuration for GPU Mining System

# Pool Configuration
POOL_URL=stratum+tcp://rvn.2miners.com:6060
WALLET_ADDRESS=YOUR_RVN_WALLET_HERE
WORKER_NAME=gpu-rig-01

# GPU Settings
GPU_POWER_LIMIT=200
GPU_TARGET_TEMP=70

# API Configuration  
API_PORT=50051
METRICS_PORT=9090

# Orchestrator Settings
MAX_WORKERS_PER_GPU=1
RESTART_DELAY=10s

# Monitoring
PROMETHEUS_RETENTION=15d
GRAFANA_ADMIN_PASSWORD=changeme

# Security
JWT_SECRET=your-secret-key-here
API_RATE_LIMIT=100

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
