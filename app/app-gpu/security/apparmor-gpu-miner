# AppArmor profile for GPU Miner Academic Research
# Academic Security Research Framework

#include <tunables/global>

profile gpu-miner /app/gpu-miner flags=(attach_disconnected,mediate_deleted) {
    #include <abstractions/base>
    #include <abstractions/nameservice>
    #include <abstractions/ssl_certs>

    # Program binary
    /app/gpu-miner r,

    # Allow execution với environment restrictions
    /bin/sh rix,
    /bin/bash rix,

    # Configuration và data directories
    /app/ r,
    /app/** rwk,

    # Temporary files (restricted)
    /tmp/** rwk,

    # System info access (readonly)
    /proc/*/stat r,
    /proc/*/maps r,
    /proc/*/status r,
    /proc/meminfo r,
    /proc/cpuinfo r,

    # GPU device access
    /dev/dri/card* rwk,
    /dev/nvidia* rwk,
    /dev/nvidiactl rwk,
    /dev/nvidia-modeset rwk,
    /dev/nvidia-uvm rwk,
    /dev/nvidia-uvm-tools rwk,

    # Network access (restricted to Prometheus)
    network inet stream,
    network inet6 stream,

    # Shared memory for GPU
    /dev/shm/ r,
    /dev/shm/** rwk,

    # User databases (passwd, group) - readonly
    /etc/passwd r,
    /etc/group r,
    /etc/nsswitch.conf r,

    # Time zone info
    /etc/localtime r,
    /usr/share/zoneinfo/** r,

    # Certificate authorities
    /etc/ssl/certs/ r,
    /etc/ssl/certs/** r,

    # Runtime libraries
    /lib/ r,
    /lib/** r,
    /usr/lib/ r,
    /usr/lib/** r,
    /lib64/ r,
    /lib64/** r,

    # OpenGL/Vulkan runtimes
    /usr/share/vulkan/icd.d/ r,
    /usr/share/vulkan/icd.d/** r,
    /usr/share/glvnd/ r,
    /usr/share/glvnd/** r,

    # NVIDIA drivers
    /usr/lib/x86_64-linux-gnu/libnvidia-* r,
    /usr/lib/nvidia/** r,

    # Security controls
    deny /proc/*/cmdline rw,
    deny /proc/*/environ rw,
    deny /sys/kernel/** rw,
    deny /sys/firmware/** rw,
    deny /proc/sys/kernel/** rw,

    # Signal handling
    signal (send,receive) peer=unconfined,

    # Resource limits - enforced by cgroups but reinforced here
    set rlimit cpu <= 3600,
    set rlimit nproc <= 1024,
    set rlimit nofile <= 4096,
    set rlimit memlock <= 128M,

    # Deny dangerous operations
    deny ptrace,
    deny mount,
    deny umount,
    deny pivot_root,
    deny /bin/mount rwx,
    deny /bin/umount rwx,

    # Logging access (readonly cho system logs)
    deny /var/log/** rw,

    # No direct hardware access except GPU
    deny /dev/mem r,
    deny /dev/kmem r,
    deny /dev/port r,
    deny /dev/hda* r,
    deny /dev/sda* r,
    deny /dev/dm-* r,

    # Academic research exemptions (with audit)
    audit deny /tmp/unknown-crypto-files w,
    audit deny /proc/crypto r,

    # Profile transition
    change_profile -> gpu-miner-child,

    # Capabilities - minimal set
    capability ipc_lock,
    capability sys_resource,

    # No network admin, raw IO, sys admin capabilities
    deny capability net_admin,
    deny capability net_raw,
    deny capability sys_admin,
    deny capability sys_rawio,
    deny capability mknod,
}