#!/bin/bash

# Enhanced Runtime Library Path for NVRTC
# Giải quyết runtime compilation context issues

# Set CUDA environment paths
export CUDA_PATH=/usr/local/cuda
export CUDA_ROOT=/usr/local/cuda
export NVRTC_LIB_PATH=/usr/local/cuda/targets/x86_64-linux/lib

# Enhanced LD_LIBRARY_PATH with NVRTC priority
export LD_LIBRARY_PATH="$NVRTC_LIB_PATH:$LD_LIBRARY_PATH"

# Additional NVRTC-specific paths
export NVRTC_CUDA_PATH=$CUDA_PATH
export CUDA_INCLUDE_DIRS=$CUDA_PATH/include

# Auto-Detect Memory Limits (Tự động phát hiện giới hạn bộ nhớ)
echo "[$(date)] Auto-detecting optimal memory limits..."

# Get system memory in GB
SYS_MEM_GB=$(free -g | awk '/^Mem:/{print $2}')
AVAIL_MEM_GB=$(free -g | awk '/^Mem:/{print $7}')

# Get GPU memory in GB (sum of all GPUs)
GPU_MEM_GB=0
if command -v nvidia-smi &> /dev/null; then
    GPU_MEM_GB=$(nvidia-smi --query-gpu=memory.total --format=csv,noheader,nounits | awk '{sum+=$1} END {print int(sum/1024)}')
fi

# Calculate optimal virtual memory limit
# Formula: 80% available system memory + 30% GPU memory + 2GB overhead
OPTIMAL_VM_GB=$(awk "BEGIN {printf \"%.0f\", ($AVAIL_MEM_GB * 0.8) + ($GPU_MEM_GB * 0.3) + 2}")
OPTIMAL_VM_KB=$((OPTIMAL_VM_GB * 1024 * 1024))


echo "[$(date)] Memory limits auto-configured:"
echo "[$(date)]   ├─ System Memory: ${SYS_MEM_GB}GB total, ${AVAIL_MEM_GB}GB available"
echo "[$(date)]   ├─ GPU Memory: ${GPU_MEM_GB}GB total VRAM"
echo "[$(date)]   ├─ Virtual Memory Limit: ${OPTIMAL_VM_GB}GB ($(ulimit -v) KB)"
echo "[$(date)]   ├─ Data Segment Limit: $((OPTIMAL_VM_GB/2))GB ($(ulimit -d) KB)"
echo "[$(date)]   └─ Stack Limit: 16MB ($(ulimit -s) KB)"

# CUDA_VISIBLE_DEVICES removed - let application auto-detect all available GPUs
# Optimize CUDA cache based on available memory
CUDA_CACHE_SIZE=$((AVAIL_MEM_GB * 1024 * 1024 * 10))  # 10MB per GB available
export CUDA_CACHE_MAXSIZE=$CUDA_CACHE_SIZE

# Pre-execution verification
echo "[Mon Jul 28 17:33:19 UTC 2025] NVRTC Enhanced Wrapper - Starting verification..."

# Verify NVRTC libraries are accessible
if ! ldconfig -p | grep -q nvrtc-builtins; then
    echo "[Mon Jul 28 17:33:19 UTC 2025] WARNING: NVRTC libraries not found in ldconfig cache, refreshing..."
    ldconfig 2>/dev/null || echo "Warning: ldconfig refresh failed"
fi

# Check critical NVRTC files exist
NVRTC_BUILTINS="/usr/local/cuda/targets/x86_64-linux/lib/libnvrtc-builtins.so.12.0.140"
if [ ! -f "$NVRTC_BUILTINS" ]; then
    echo "[Mon Jul 28 17:33:19 UTC 2025] ERROR: NVRTC builtins library not found at $NVRTC_BUILTINS"
    exit 1
fi

# Verify library is readable
if [ ! -r "$NVRTC_BUILTINS" ]; then
    echo "[Mon Jul 28 17:33:19 UTC 2025] ERROR: NVRTC builtins library not readable"
    exit 1
fi

echo "[$(date)] NVRTC Enhanced Wrapper - Verification complete. Preparing to start inference-cuda..."
# Remove GPU spoof hooks to avoid memory allocation issues
unset LD_PRELOAD
echo "[$(date)] LD_PRELOAD unset to disable GPU hooks"
echo "[Mon Jul 28 17:33:19 UTC 2025] LD_LIBRARY_PATH: $LD_LIBRARY_PATH"
echo "[Mon Jul 28 17:33:19 UTC 2025] CUDA_PATH: $CUDA_PATH"

# Execute original program with enhanced environment and error handling
echo "[$(date)] Starting inference-cuda with memory limits..."
if [ -x "/app/inference-cuda.original" ]; then
    exec /app/inference-cuda.original "$@"
else
    echo "[$(date)] ERROR: /app/inference-cuda.original not found or not executable"
    exit 1
fi
