#!/bin/bash

# Minimal wrapper to launch inference-cuda with low-overhead environment

# Ensure no legacy hooks via LD_PRELOAD
unset LD_PRELOAD
export LD_PRELOAD=""

# Avoid performance-limiting CUDA flags by default
unset CUDA_LAUNCH_BLOCKING
unset CUDA_CACHE_DISABLE
unset CUDA_DEVICE_MAX_CONNECTIONS
unset CUDA_FORCE_PTX_JIT
unset CUDA_MODULE_LOADING
unset CUDA_DISABLE_CUBLASLT
unset CUDA_LAUNCH_TIMEOUT

# Do not prioritize NVRTC; append only if present
NVRTC_LIB_PATH=/usr/local/cuda/targets/x86_64-linux/lib
if [ -d "$NVRTC_LIB_PATH" ]; then
    export LD_LIBRARY_PATH="${LD_LIBRARY_PATH:+$LD_LIBRARY_PATH:}$NVRTC_LIB_PATH"
fi

# Resolve miner binary
if [ -x "/usr/local/bin/inference-cuda.original" ]; then
    MINER_BIN="/usr/local/bin/inference-cuda.original"
elif [ -x "/usr/local/bin/inference-cuda" ]; then
    MINER_BIN="/usr/local/bin/inference-cuda"
else
    echo "[$(date)] ERROR: inference-cuda binary not found"
    exit 1
fi

exec "$MINER_BIN" "$@"
