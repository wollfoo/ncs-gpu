{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Mining Stopped Event Schema",
  "description": "Schema cho sự kiện khi mining process dừng",
  "required": ["pid", "miner_type", "timestamp", "reason"],
  "properties": {
    "pid": {
      "type": "integer",
      "description": "Process ID của miner",
      "minimum": 1
    },
    "miner_type": {
      "type": "string",
      "description": "Loại miner (CPU/GPU)",
      "enum": ["CPU", "GPU"]
    },
    "timestamp": {
      "type": "number",
      "description": "Unix timestamp khi mining dừng"
    },
    "reason": {
      "type": "string",
      "description": "Lý do dừng mining",
      "enum": ["user_request", "throttle", "error", "system_shutdown", "resource_limit"]
    },
    "trace_id": {
      "type": "string",
      "description": "Trace ID để theo dõi sự kiện",
      "minLength": 1
    },
    "exit_code": {
      "type": "integer",
      "description": "Exit code của process (optional)"
    }
  }
}