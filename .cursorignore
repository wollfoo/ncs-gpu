cleanup_*.log
cleanup_*.json
cleanup_*.sh
*_dependency_analyzer.py
dependency_analysis_*

# Temporary analysis files
analysis_*
report_*
*.analysis

# ============================== PERFORMANCE & MONITORING ==============================
# Performance monitoring
perf_*
profile_*
*.prof
*.profile

# Resource monitoring (exclude core files)
resource_*.log
resource_report*
resource_dump*
resource_analysis*
resource_temp*
# Allow critical resource config files
!**/resource_config.json
!**/resource_manager.py
!**/resource_optimization.json
monitor_*

# System info dumps
sysinfo_*
hwinfo_*

# ============================== PACKAGES & BINARIES ==============================
